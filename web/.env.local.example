# ================================================================
# Variables de entorno — Sistema ACH/TEF
#
# 1. Copia este archivo: cp .env.local.example .env.local
# 2. Rellena los valores desde tu proyecto en supabase.com
# 3. En Vercel: Settings → Environment Variables → agregar las mismas
# ================================================================

# ── Supabase ──────────────────────────────────────────────────────
# Obtener en: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key — SOLO para API Routes (nunca exponer al cliente)
# Obtener en: Supabase → Project Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (emails) ───────────────────────────────────────────────
# Plan gratuito: 3.000 emails/mes — https://resend.com
# Crear cuenta → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (SMS Colombia +57) ─────────────────────────────────────
# https://www.twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número de Twilio (formato E.164): +1xxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
